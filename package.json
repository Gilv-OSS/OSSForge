{
  "name": "ossforge",
  "productName": "OSSForge",
  "version": "0.1.0",
  "description": "Autonomous Freelance Engineering Platform / Multi-Agent IDE Environment",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "package": "electron-builder --win --x64"
  },
  "keywords": [
    "AI",
    "Multi-Agent",
    "IDE",
    "Docker",
    "Freelance",
    "Software Engineering",
    "Nelua"
  ],
  "author": "OSSForge Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.4.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "dockerode": "^3.3.5",
    "electron-store": "^8.1.0",
    "monaco-editor": "^0.40.0",
    "node-pty": "^1.0.0",
    "simple-git": "^3.19.0",
    "xterm": "^5.2.1"
  },
  "build": {
    "appId": "com.ossforge.app",
    "productName": "OSSForge",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}